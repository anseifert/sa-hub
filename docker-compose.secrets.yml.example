# Optional: store the bcrypt hash in a file instead of .env
# Usage:
#   docker compose exec backend python scripts/hash_password.py 'your password' > secrets/auth_password_hash
#   chmod 600 secrets/auth_password_hash
#   docker compose -f docker-compose.yml -f docker-compose.secrets.yml.example up -d

services:
  backend:
    environment:
      - AUTH_PASSWORD_HASH_FILE=/run/secrets/auth_password_hash
      - AUTH_PASSWORD=
      - AUTH_PASSWORD_HASH=
    secrets:
      - auth_password_hash

secrets:
  auth_password_hash:
    file: ./secrets/auth_password_hash
