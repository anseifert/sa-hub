# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Local LLM (Ollama — runs in Docker, no API key required)
LLM_BASE_URL=http://ollama:11434/v1
LLM_MODEL=qwen2.5:7b-instruct
# Pull on host: podman exec -it sa-hub-ollama ollama pull qwen2.5:7b-instruct
# ENRICH_MAX_CONTACTS=150
# SYNC_AI_ENABLED=false
# ENRICH_CONTACTS=false

# Slack (https://api.slack.com/apps) - add when IT approves
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_BOT_TOKEN=

# App secret for session signing (required when AUTH_* is set)
SECRET_KEY=change_me_to_a_random_string_32_chars

# App login (required for public HTTPS deployment — see README)
AUTH_USERNAME=your_username
# Generate hash: docker compose exec backend python scripts/hash_password.py 'your password'
# In .env, escape each $ as $$ for Docker Compose (e.g. $$2b$$12$$...)
# Or use secrets/auth_password_hash + docker-compose.secrets.yml.example
AUTH_PASSWORD_HASH=
# Plain password (deprecated — use AUTH_PASSWORD_HASH or secrets file instead)
# AUTH_PASSWORD=

# Public URL (HTTPS + your domain for production) — plain URL only, no trailing }
# PUBLIC_URL=https://sa-hub.example.com
# FRONTEND_URL=https://sa-hub.example.com
# GOOGLE_REDIRECT_URI=https://sa-hub.example.com/api/auth/google/callback

# Local / WiFiMan via SSH tunnel — leave PUBLIC_URL unset or use localhost
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
